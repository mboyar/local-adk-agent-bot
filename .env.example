TELEGRAM_TOKEN=your-telegram-bot-token-here

# Ollama API base URL (set this if Ollama runs on a different machine)
# Default is http://localhost:11434 when not set
OLLAMA_API_BASE=http://localhost:11434

# ADK agent app name (must match the folder/symlink name the ADK server sees)
ADK_APP_NAME=my_agent

# ADK API server URL
ADK_API_URL=http://localhost:8000/run

# Siemens Home Connect API secrets (for siemens-home-connect-tool.py)
HOME_CONNECT_CLIENTID=your_client_id_here
HOME_CONNECT_DEVICECODE=your_device_code_here
HOME_CONNECT_ACCESSTOKEN=your_access_token_here
HOME_CONNECT_REFRESHTOKEN=your_refresh_token_here
HOME_CONNECT_HAID_DISHWASHER=your_dishwasher_haid_here_optional
HOME_CONNECT_HAID_FRIDGEFREEZER=your_fridgefreezer_haid_here_optional
